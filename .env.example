# Docker BuildKit
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1

# Which Kokoro profile to bring up. Options: cpu, gpu
# Run ./scripts/kokoro-detect.sh for a recommendation tailored to your host.
COMPOSE_PROFILES=cpu

# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# Ollama Configuration
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:31b-cloud

# Kokoro TTS
# Browse voices at http://localhost:8880/v1/audio/voices once the service is up.
# Popular English voices: af_heart, af_bella, af_sky, am_michael, bf_emma
#
# Accelerator picker — run ./scripts/kokoro-detect.sh for a recommendation.
# Toggle via COMPOSE_PROFILES above.
#   COMPOSE_PROFILES=cpu           : CPU image (multi-arch; ARM64-native on Mac) — DEFAULT
#   COMPOSE_PROFILES=gpu           : NVIDIA CUDA image (requires nvidia-container-toolkit)
#   macOS Apple Silicon (Metal)    : ./scripts/kokoro-mlx-native.sh  (native, host-run)
#   AMD GPU (Linux ROCm)           : build the moritzchow/Kokoro-FastAPI-ROCm fork
KOKORO_URL=http://localhost:8880
KOKORO_VOICE=af_heart

# Authentication
# Shared HS256 secret used by FastAPI to sign+verify session JWTs (32+ bytes).
# Generate with:  openssl rand -hex 32
AUTH_JWT_SECRET=
AUTH_JWT_ISSUER=careerlift
AUTH_JWT_TTL_HOURS=720

# Auth.js (NextAuth v5) — uses AUTH_* convention
AUTH_URL=http://localhost:3000
AUTH_SECRET=
AUTH_TRUST_HOST=true

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Microsoft OAuth (Entra ID / Azure AD) — https://entra.microsoft.com (App registrations)
# Authorized redirect URI: http://localhost:3000/api/auth/callback/microsoft-entra-id
# Tenant: 'common' for personal+work, or your tenant id
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_TENANT_ID=common

# Bootstrapped seed user (auto-created on first FastAPI startup, owns existing data)
BOOTSTRAP_USER_EMAIL=user@careerlift.local
BOOTSTRAP_USER_PASSWORD=changeme
BOOTSTRAP_USER_NAME=user

# Backend Configuration
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NODE_ENV=development

# Electron Configuration
ELECTRON_START_URL=http://localhost:3000

# Job Finder API Keys
# USAJOBS API - https://developer.usajobs.gov/
USAJOBS_API_KEY=
USAJOBS_EMAIL=

# Adzuna API - https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
